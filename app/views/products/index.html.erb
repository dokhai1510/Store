<h1 class="text-center my-4"><%= t ".title" %></h1>

<div class="text-center mb-4">
  <%= link_to "New product", new_product_path, class: "btn btn-primary" if authenticated? %>
  <%= link_to "Login", new_session_path, class: "btn btn-secondary" unless authenticated? %>
</div>

<div id="products" class="container">
  <div class="row">
    <% @products.each do |product| %>
      <div class="col-md-4 mb-4">
        <div class="card">
          <div class="card-body">
            <h5 class="card-title"><%= link_to product.name, product, class: "text-decoration-none" %></h5>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
